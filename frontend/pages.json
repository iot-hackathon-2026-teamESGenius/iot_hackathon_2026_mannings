{
  "easycom": {
    "autoscan": true,
    "^uni-(.*)": "@/uni_modules/uni-1/components/uni-1/uni-$1.vue",
	"^qiun-(.*)": "@/uni_modules/qiun-1/components/qiun-1/qiun-$1.vue"
  },
  "pages": [
	  {
	  		"path": "pages/login",
	  		"style": {
	  			"navigationBarTitleText": "LOGIN IN"
	  		}
	},
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首頁",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/my", 
      "style": {
        "navigationBarTitleText": "個人中心",
		"navigationStyle": "custom"
      }
    },
    {
      "path": "pages/index/replenishment",
      "style": { 
		  "navigationBarTitleText": "補貨管理" ,
		  "navigationStyle": "custom"
		  }
	},
	{
	"path": "pages/index/deliever_map",
	"style": {
		"navigationBarTitleText": "配送地圖",
		"navigationStyle": "custom"
	}
},
{
	"path": "pages/index/forcast",
	"style": {
		"navigationBarTitleText": "需求預測",
		"navigationStyle": "custom"
	}
}
],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#8a8a8a",
    "selectedColor": "#0066CC",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首頁",
        "iconPath": "static/img/home.png",
        "selectedIconPath": "static/img/home-selected.png"
      },
      {
        "pagePath": "pages/index/forcast",
        "text": "需求預測",
        "iconPath": "static/img/cate.png",
        "selectedIconPath": "static/img/cate-selected.png"
      },
      {
        "pagePath": "pages/index/replenishment",
        "text": "補貨",
        "iconPath": "static/img/collect.png",
        "selectedIconPath": "static/img/collect-selected.png"
      },
      {
        "pagePath": "pages/index/deliever_map",
        "text": "調度",
        "iconPath": "static/img/x5.png",
        "selectedIconPath": "static/img/x6.png"
      },
      {
        "pagePath": "pages/my",
        "text": "個人中心",
        "iconPath": "static/img/me.png",
        "selectedIconPath": "static/img/me-selected.png"
      }
    ]
  }
}